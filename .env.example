# Auth0 (required for JWT verification)
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com/
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_MFA_ACR=

# Server
PORT=3000

# Database
DATABASE_URL=postgresql://...

# Google OAuth (for integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
